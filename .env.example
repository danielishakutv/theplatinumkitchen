# --- Database -----------------------------------------------------------------
# Local Docker (matches docker-compose.yml):
DATABASE_URL=postgres://platinum:platinum_dev@localhost:5433/platinum_kitchen

# Neon / hosted Postgres (example):
# DATABASE_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/platinum_kitchen?sslmode=require

# --- Auth ---------------------------------------------------------------------
# Generate with: openssl rand -base64 32   (or any 32-byte random string)
AUTH_SECRET=replace-with-32-byte-random-string
# Public URL of the site. In production: https://theplatinumkitchen.com
AUTH_URL=http://localhost:3000

# --- App ----------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Platinum Kitchen"
