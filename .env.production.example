# Copy to .env.production on the VPS and fill in real values.
# Used by docker-compose.prod.yml (`--env-file .env.production`).
# DO NOT commit the filled file.

# --- Postgres -----------------------------------------------------------------
# The container creates the DB + user on first run from these.
POSTGRES_DB=platinum_kitchen
POSTGRES_USER=platinum
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=replace-with-strong-random

# --- App ---------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-32-byte-random-string

# Canonical public origin. Auth.js uses this to validate callbacks.
# Set this to the FRONTEND domain — sign-in cookies are issued here.
AUTH_URL=https://theplatinumkitchen.com

NEXT_PUBLIC_APP_NAME=Platinum Kitchen

# --- Optional ----------------------------------------------------------------
# RESEND_API_KEY=re_... (added when the notifications module is wired)
